# ─────────────────────────────────────────────────────────────
# product-reader-ai – environment variables
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# GitHub personal access token.
# Required scopes: repo (full), workflow
GITHUB_TOKEN=ghp_...

# owner/repo of the repository where the profile will be committed.
# Example: my-org/my-configs
TARGET_REPO=owner/repo

# Branch to create the new feature branch from (default: main)
BASE_BRANCH=main

# Comma-separated list of webshop URLs the agent should browse.
# Example: https://www.example-shop.com/products,https://shop2.example.com
WEBSHOP_URLS=https://www.example-shop.com/products

# Path inside TARGET_REPO (on BASE_BRANCH) that contains feature/product test files.
# The agent reads these to learn the exact profile JSON schema before generating anything.
# Default: features/products
FEATURES_PATH=features/products

# Path inside TARGET_REPO (on BASE_BRANCH) that contains mock HTML pages.
# The agent reads these to learn the test scenario file structure.
# Default: public/mock
MOCKS_PATH=public/mock

# Output path in TARGET_REPO where generated profile files will be committed.
# Default: validation/profiles
PROFILES_PATH=validation/profiles

# Output path in TARGET_REPO where generated test scenario files will be committed.
# Default: validation/tests
TESTS_PATH=validation/tests

# Name of the GitHub Actions workflow that generates baseline validation artifacts.
# Default: Validation — Generate Baseline
GENERATE_BASELINE_WORKFLOW=Validation — Generate Baseline

# Name of the GitHub Actions workflow that accepts a validated baseline.
# Default: Validation — Accept Baseline
ACCEPT_BASELINE_WORKFLOW=Validation — Accept Baseline

# ─── Amazon Bedrock (LLM backend) ────────────────────────────
# AWS region where Bedrock is available (default: us-east-1)
AWS_REGION=us-east-1

# Bedrock model ID (default: us.anthropic.claude-sonnet-4-5-v1:0)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-v1:0

# AWS credentials – leave blank if you rely on instance profile / env / ~/.aws
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ─── GitHub MCP server ───────────────────────────────────────
# Full command used to launch the GitHub MCP server (space-separated).
# The first token is the executable; everything after it becomes the arguments.
# GITHUB_PERSONAL_ACCESS_TOKEN is always injected into the process environment,
# so you can safely pass "-e GITHUB_PERSONAL_ACCESS_TOKEN" for container runtimes.
#
# Leave blank to use a local `github-mcp-server` binary on your PATH.
#
# Examples:
#   Docker:
#     GITHUB_MCP_COMMAND=docker run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN -e GITHUB_TOOLSETS ghcr.io/github/github-mcp-server
#
#   Podman:
#     GITHUB_MCP_COMMAND=podman run -i --rm -e GITHUB_PERSONAL_ACCESS_TOKEN -e GITHUB_TOOLSETS ghcr.io/github/github-mcp-server
#
#   Custom binary path:
#     GITHUB_MCP_COMMAND=/usr/local/bin/github-mcp-server stdio
#
GITHUB_MCP_COMMAND=

# ─── Browser settings ────────────────────────────────────────
# Run Chromium in headless mode (recommended for CI): true / false
STRANDS_BROWSER_HEADLESS=true
