# ─────────────────────────────────────────────────────────────
# product-reader-ai – environment variables
# Copy this file to .env and fill in the values.
# The .env file is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# GitHub personal access token.
# Required scopes: repo (full), workflow
GITHUB_TOKEN=ghp_...

# owner/repo of the repository where the profile will be committed.
# Example: my-org/my-configs
TARGET_REPO=owner/repo

# Branch to create the new feature branch from (default: main)
BASE_BRANCH=main

# Name of the new branch that will be created (default: feature/product-profile)
NEW_BRANCH=feature/product-profile

# Comma-separated list of webshop URLs the agent should browse.
# Example: https://www.example-shop.com/products,https://shop2.example.com
WEBSHOP_URLS=https://www.example-shop.com/products

# Directory inside TARGET_REPO (on BASE_BRANCH) that contains sample profile.json
# files and/or mocked webshop HTML files the agent should learn from before
# generating its own profile.  The agent will read these files via the GitHub MCP
# tools and mirror their schema and style.
# Default: examples
EXAMPLES_PATH=examples

# GitHub Actions workflow file name (or full workflow name) to run for validation.
# This workflow should validate the committed profile.json and upload an artifact.
VALIDATE_WORKFLOW=validate.yml

# GitHub Actions workflow file name (or full workflow name) to run after validation.
# This workflow performs the publish/deploy step.
PUBLISH_WORKFLOW=publish.yml

# ─── Amazon Bedrock (LLM backend) ────────────────────────────
# AWS region where Bedrock is available (default: us-east-1)
AWS_REGION=us-east-1

# Bedrock model ID (default: us.anthropic.claude-sonnet-4-5-v1:0)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-v1:0

# AWS credentials – leave blank if you rely on instance profile / env / ~/.aws
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ─── Browser settings ────────────────────────────────────────
# Run Chromium in headless mode (recommended for CI): true / false
STRANDS_BROWSER_HEADLESS=true
